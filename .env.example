# EduSpaceAI environment configuration template.
# Copy to .env.local for development and fill in real values.
# NEVER commit .env.local to git.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# MongoDB connection string (Atlas or self-hosted). Required.
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/eduspace?retryWrites=true&w=majority

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Long random string used to sign session JWTs. Required.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string

# Google OAuth client ID for Google login (used by the GIS library on the
# client and server-side ID-token verification on the server).
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ---------------------------------------------------------------------------
# AI providers
# ---------------------------------------------------------------------------
# Google AI Studio / Gemini API key.
GEMINI_API_KEY=

# Anthropic API key (used for the Claude tier).
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Web search & content extraction (deep-search agent)
# ---------------------------------------------------------------------------
TAVILY_API_KEY=
JINA_API_KEY=

# ---------------------------------------------------------------------------
# Payments — Midtrans
# ---------------------------------------------------------------------------
# Server-side Midtrans credentials (used by /api/webhook/midtrans and
# subscriptionActions.createTransaction).
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
# Set to "true" to talk to the production Midtrans API. Leave unset / "false"
# to use the sandbox.
MIDTRANS_IS_PRODUCTION=false

# Same values exposed to the browser (used to load the correct Snap script and
# pass the client key into snap.pay()).
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# ---------------------------------------------------------------------------
# Next.js runtime
# ---------------------------------------------------------------------------
# Optional: set in production deployments so HSTS and secure cookies activate.
# NODE_ENV=production
