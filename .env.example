# Database Configuration
# Dapatkan dari MongoDB Atlas atau instance MongoDB lokal Anda
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/eduspace

# AI Model API Keys
# Dapatkan dari https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# Dapatkan dari https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Authentication Configuration
# String acak untuk menandatangani token JWT
JWT_SECRET=your_jwt_secret_here

# Google OAuth Configuration
# Dapatkan dari Google Cloud Console -> Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Midtrans Payment Gateway Configuration
# Dapatkan dari Dashboard Midtrans -> Settings -> Access Keys
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here
MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here

# Environment
NODE_ENV=development
